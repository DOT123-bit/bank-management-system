<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Accounts - Bank Management System</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="page">
        <header class="hero">
            <div>
                <p class="tag">Account Management</p>
                <h1>Manage Accounts</h1>
                <p class="subtitle">Create, search, deposit, withdraw, and delete bank accounts.</p>
            </div>
            <div class="hero-actions">
                <a class="nav-btn" href="/dashboard">Dashboard</a>
                <a class="nav-btn light" href="/transactions">Transactions</a>
                <a class="nav-btn danger" href="/logout">Logout</a>
            </div>
        </header>

        <section class="search-card card">
            <div class="section-title-row">
                <h2>Search Account</h2>
                <a class="show-all-btn" href="/bank">Show All</a>
            </div>

            <form action="/search" method="GET" class="single-form">
                <input
                    type="text"
                    name="accountNumber"
                    placeholder="Enter account number to search"
                    value="<%= searchValue %>"
                >
                <button type="submit">Search</button>
            </form>
        </section>

        <section class="grid-2">
            <div class="card">
                <h2>Create Account</h2>
                <form action="/create" method="POST" class="stack-form">
                    <input type="text" name="name" placeholder="Customer Name" required>
                    <input type="text" name="accountNumber" placeholder="Account Number" required>
                    <input type="number" step="0.01" name="balance" placeholder="Initial Balance" required>
                    <button type="submit">Create Account</button>
                </form>
            </div>

            <div class="card">
                <h2>Deposit Money</h2>
                <form action="/deposit" method="POST" class="stack-form">
                    <input type="text" name="accountNumber" placeholder="Account Number" required>
                    <input type="number" step="0.01" name="amount" placeholder="Amount" required>
                    <button type="submit">Deposit</button>
                </form>
            </div>
        </section>

        <section class="card">
            <h2>Withdraw Money</h2>
            <form action="/withdraw" method="POST" class="stack-form">
                <input type="text" name="accountNumber" placeholder="Account Number" required>
                <input type="number" step="0.01" name="amount" placeholder="Amount" required>
                <button type="submit">Withdraw</button>
            </form>
        </section>

        <section class="card table-card">
            <div class="section-title-row">
                <h2>All Accounts</h2>
                <span class="record-count">Total: <%= accounts.length %></span>
            </div>

            <% if (accounts.length === 0) { %>
                <div class="empty-box">
                    <p>No accounts found.</p>
                </div>
            <% } else { %>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Account Number</th>
                                <th>Balance</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% accounts.forEach(acc => { %>
                                <tr>
                                    <td><%= acc.id %></td>
                                    <td><%= acc.name %></td>
                                    <td><%= acc.accountNumber %></td>
                                    <td class="balance-cell">₹ <%= acc.balance %></td>
                                    <td>
                                        <form action="/delete/<%= acc.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this account?')">
                                            <button type="submit" class="delete-btn">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>
    </div>
</body>
</html>